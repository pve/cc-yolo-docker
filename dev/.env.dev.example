# Copy to .env.dev and fill in values before running scripts/spawn-dev.sh
# Never commit .env.dev to git.

# ── Target project ────────────────────────────────────────────────────────────

# GitHub user or org that owns the fork
GITHUB_USER=youruser

# Fork to develop (user/repo format)
FORK_REPO_PATH=youruser/your-repo

# Upstream to sync from (HTTPS URL)
UPSTREAM_URL=https://github.com/upstream-org/upstream-repo.git

# Container registry for built images (without tag)
REGISTRY=ghcr.io/youruser/your-repo

# ── GitHub auth ───────────────────────────────────────────────────────────────

# GitHub Personal Access Token (fine-grained recommended)
#
# Create at: https://github.com/settings/personal-access-tokens/new
#
# Fine-grained PAT — set these repository permissions on FORK_REPO_PATH:
#   Contents:       Read and write   (clone, push commits)
#   Pull requests:  Read and write   (gh pr create)
#   Administration: Read and write   (add/remove deploy keys via API)
#   Metadata:       Read (auto)
#
# Also set this account permission:
#   Packages:       Read and write   (push/pull ghcr.io images)
#
# Set an expiry (90 days recommended) and rotate before it expires.
# Never commit this file — it is listed in .gitignore.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# ── Git identity ──────────────────────────────────────────────────────────────

# Used for commits made inside cc-dev containers
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=you@example.com

# ── SSH access ────────────────────────────────────────────────────────────────

# Your local machine's public key — contents of ~/.ssh/id_ed25519.pub (or id_rsa.pub)
# Written to /root/.ssh/authorized_keys inside each cc-dev container.
SSH_AUTHORIZED_KEY=ssh-ed25519 AAAA...
