# Copy to .env.dev and fill in values before running scripts/spawn-dev.sh
# Never commit .env.dev to git.

# ── Target project ────────────────────────────────────────────────────────────

# GitHub user or org that owns the fork
GITHUB_USER=youruser

# Fork to develop (user/repo format)
FORK_REPO_PATH=youruser/your-repo

# Upstream to sync from (HTTPS URL)
UPSTREAM_URL=https://github.com/upstream-org/upstream-repo.git

# Container registry for built images (without tag)
REGISTRY=ghcr.io/youruser/your-repo

# ── GitHub auth ───────────────────────────────────────────────────────────────

# GitHub Personal Access Token — use a CLASSIC PAT (not fine-grained)
# Fine-grained PATs do not yet fully support pushing to ghcr.io.
#
# Create at: https://github.com/settings/tokens/new
#
# Required scopes:
#   repo            — clone, push, PRs, deploy key management via API
#   write:packages  — push images to ghcr.io
#   read:packages   — pull images from ghcr.io
#
# Set an expiry (90 days recommended). Never commit this file.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Git identity ──────────────────────────────────────────────────────────────

# Used for commits made inside cc-dev containers
GIT_AUTHOR_NAME="Your Name"
GIT_AUTHOR_EMAIL=you@example.com

# ── SSH access ────────────────────────────────────────────────────────────────

# Your local machine's public key — contents of ~/.ssh/id_ed25519.pub (or id_rsa.pub)
# Written to /root/.ssh/authorized_keys inside each cc-dev container.
SSH_AUTHORIZED_KEY="ssh-ed25519 AAAA..."

# ── AI provider keys ──────────────────────────────────────────────────────────

# OpenRouter API key — used by nanobot as its AI backend
# Create at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# ── Claude Code auth ──────────────────────────────────────────────────────────

# OAuth token for Claude Code — bypasses macOS Keychain (which is unavailable
# in containers and SSH sessions). Extract from your local machine with:
#   security find-generic-password -s "Claude Code-credentials" -w
#
# This token persists across container rebuilds without needing 'claude' login.
CLAUDE_CODE_OAUTH_TOKEN=
